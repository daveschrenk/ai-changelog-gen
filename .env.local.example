# =============================================================================
# AI Changelog Generator — Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# LLM — Anthropic (required for real changelog generation)
# Get your key at: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Model to use (optional — defaults to claude-haiku-4-5 for cost efficiency)
# Uncomment to use higher-quality model:
# LLM_MODEL=claude-sonnet-4-5

# Mock mode — returns deterministic fixture WITHOUT calling Anthropic API
# Use this for local development and testing (Gus: set this to true)
# MOCK_LLM=true

# -----------------------------------------------------------------------------
# Supabase (required for persistent rate limiting + paid user tracking)
# 1. Create free project at: https://supabase.com
# 2. Run supabase/schema.sql in the SQL editor
# 3. Copy values from: Project Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Stripe (required for Pro tier billing — $9/month)
# 1. Create account at: https://stripe.com
# 2. Create a product "AI Changelog Generator Pro" with $9/month recurring price
# 3. Copy values from: Stripe Dashboard → Developers → API keys
# 4. Create webhook pointing to: https://your-domain.vercel.app/api/stripe/webhook
#    Events to listen for: checkout.session.completed, customer.subscription.deleted
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PAID_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# App URL (used for redirect URLs and rate limit upgrade links)
# Local dev: http://localhost:3000
# Production: your Vercel URL (e.g. https://ai-changelog-gen.vercel.app)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
